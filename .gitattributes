# Auto detect text files and perform LF normalization
* text=auto

# Python
*.py text eol=lf
*.pyc binary

# Docker
Dockerfile text eol=lf
.dockerignore text eol=lf

# Configs
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.toml text eol=lf
*.ini text eol=lf
*.example text eol=lf
.env* text eol=lf

# Docs
*.md text eol=lf
*.txt text eol=lf
